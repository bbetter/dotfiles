/* ==================================================
   FLOATING MODULES WAYBAR - TRANSPARENT
   ================================================== */

* {
    font-family: "JetBrainsMono Nerd Font", "Noto Sans", sans-serif;
    font-size: 13px;
    min-height: 0;
    font-weight: 500;
}

window#waybar {
    background: transparent;
    color: #ffffff;
}

/* MODULES */
#custom-audio,
#custom-peripherals,
#custom-network,
#custom-notification,
#custom-recording,
#custom-jarvis,
#custom-media-cava,
#custom-window,
#clock,
#language,
#tray {
    background: rgba(13, 13, 13, 0.8);
    padding: 3px 12px;
    margin: 3px 6px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

#workspaces {
    background: rgba(13, 13, 13, 0.8);
    padding: 2px 6px;
    margin: 3px 6px;
    border-radius: 10px;
}

/* 👇 ОСНОВНИЙ АКЦЕНТ (уніфікований) */
#workspaces button.active,
#workspaces button.focused {
    color: #33ccff;
    border-bottom-color: #33ccff;
}

/* 👇 ERROR */
#workspaces button.urgent {
    color: #ff6b6b;
    border-bottom-color: #ff6b6b;
}

/* 👇 SUCCESS */
#custom-media-cava.playing,
#custom-notification {
    color: #a6e3a1;
}

/* 👇 WARNING */
#custom-media-cava.paused {
    color: #f9e2af;
}

/* 👇 SECONDARY */
#custom-audio,
#custom-peripherals,
#custom-network {
    color: #89b4fa;
}

/* TOOLTIP */
tooltip {
    background: rgba(13, 13, 13, 0.95);
    border: 1px solid rgba(51, 204, 255, 0.3);
}
